{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm ci --only=production"
  },
  "deploy": {
    "startCommand": "cd server && node index.js",
"restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
