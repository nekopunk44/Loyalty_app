# Frontend Configuration (Expo)
# Copy this file to .env and fill in your values

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:5002/api
EXPO_PUBLIC_ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars
EXPO_PUBLIC_ENV=development

# Payment API Keys
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
EXPO_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# App Configuration
EXPO_PUBLIC_APP_NAME=Villa Jaconda
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_LOG_LEVEL=info

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# Sentry (React Native error monitoring)
EXPO_PUBLIC_SENTRY_DSN=
