{
  "expo": {
    "name": "Villa Jaconda Loyalty",
    "slug": "villa-jaconda-loyalty",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "villajaconda",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0A08"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.villajaconda.loyalty",
      "infoPlist": {
        "NSCameraUsageDescription": "Разрешить доступ к камере для сканирования QR-кодов"
      }
    },
    "android": {
      "package": "com.villajaconda.loyalty",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0A08"
      },
      "permissions": [
        "INTERNET",
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./src/assets/property1.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешить доступ к камере для сканирования QR-кодов"
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "organization": "other-c6",
          "project": "react-native"
        }
      ],
      "expo-web-browser"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "18b3a329-69ad-4b22-ace7-1aa7a4c0b4be"
      }
    },
    "owner": "nekopunk"
  }
}
