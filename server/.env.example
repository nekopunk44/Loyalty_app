# ==================== SERVER CONFIGURATION ====================
PORT=5002
NODE_ENV=development
# Public base URL of this server (used for building asset URLs)
# In production: https://api.villa-jaconda.com
API_BASE_URL=http://localhost:5002

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://username:your_secure_password@localhost:5432/loyalty_app

# ==================== SECURITY - JWT ====================
# Generate with: openssl rand -base64 32
# REQUIRED IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-change-in-production-must-be-long-and-random!
JWT_EXPIRE=7d

# Demo payments immediately credit balances. Keep false in production.
ALLOW_DEMO_PAYMENTS=true

# ==================== CORS ====================
# Comma-separated, no spaces
CORS_ORIGIN=http://localhost:3000,http://localhost:5002,http://localhost:8081,http://localhost:19006,http://localhost:19000

# ==================== HOST GUARD (production only) ====================
# Comma-separated list of allowed Host headers (protects against Host-header injection
# in password-reset links). Only enforced when NODE_ENV=production.
# Format: hostname:port  — include port if not 80/443.
# Example: ALLOWED_HOSTS=api.villa-jaconda.com,api.villa-jaconda.com:443
ALLOWED_HOSTS=localhost:5002,127.0.0.1:5002

# ==================== STRIPE ====================
# Get keys at https://dashboard.stripe.com/test/apikeys (Test mode)
STRIPE_SECRET_KEY=sk_test_your_actual_key_here
# Webhook secret: создаётся при добавлении endpoint'а в
# https://dashboard.stripe.com/test/webhooks
# URL endpoint: <RAILWAY_URL>/api/payments/stripe/webhook
# События: checkout.session.completed, checkout.session.expired,
#          checkout.session.async_payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_actual_secret_here
# Publishable key (только клиент, не используется на сервере — для справки)
# STRIPE_PUBLISHABLE_KEY=pk_test_your_actual_key_here

# ==================== PAYPAL (Sandbox) ====================
# Apps & Credentials → Sandbox → Create App at https://developer.paypal.com
PAYPAL_CLIENT_ID=your_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret
PAYPAL_ENV=sandbox

# ==================== APP DEEP-LINK SCHEME ====================
# Должно совпадать с expo.scheme в app.json (используется для возврата
# из браузера после оплаты Stripe / PayPal). По умолчанию villajaconda.
APP_SCHEME=villajaconda

# ==================== CURRENCY EXCHANGE (PRB ↔ внешние валюты) ====================
# Внутренняя валюта приложения — PRB (приднестровский рубль).
# Платёжные провайдеры принимают RUB/USD. Курсы: 1 единица внешней
# валюты = X PRB. Корректируй под актуальный курс ПРБ.
# (TODO: автоматическое обновление с публичного API https://www.cbpmr.net/)
PRB_RATE_RUB=0.18
PRB_RATE_USD=16.10

# ==================== EMAIL (Optional) ====================
# Frontend base URL used in password-reset links sent by email
APP_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=noreply@villa-jaconda.com

# ==================== OPENROUTER AI ====================
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Model to use, e.g. openai/gpt-4o-mini  mistralai/mistral-7b-instruct  anthropic/claude-3-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini

# ==================== ML SERVICE (Intelligent Loyalty Engine) ====================
# Python FastAPI микросервис в server/ml/ (RFM-сегментация, churn-прогноз, рекомендации).
# Если ML недоступен — Express продолжает работать (graceful fallback).
ML_SERVICE_URL=http://localhost:8001
# Токен должен совпадать с ML_SERVICE_TOKEN в server/ml/.env
ML_SERVICE_TOKEN=dev-token
# Таймаут одного запроса к ML, мс
ML_TIMEOUT_MS=8000
# Число повторов при сетевой ошибке или 5xx
ML_RETRIES=2

# Фоновые ML-задачи (cron). При деплое >1 инстанса — включать только на одном.
ML_JOBS_ENABLED=true
# Cron-выражения по локальному времени Europe/Moscow
ML_JOB_RFM_CRON=0 3 * * *
ML_JOB_CHURN_CRON=0 4 * * *
# Окно «активных пользователей» для churn-проверки, дней
ML_JOB_CHURN_ACTIVE_DAYS=90
# Размер батча параллельных вызовов churn/predict
ML_JOB_CHURN_BATCH=20

# ==================== ERROR MONITORING ====================
# Получить DSN: https://sentry.io → новый проект → Node.js
# Если не задан, мониторинг отключён (в production выдаёт предупреждение)
SENTRY_DSN=

# ==================== IMPORTANT ====================
# 1. NEVER commit this file with real values to git
# 2. Generate strong random strings (min 32 chars) for all SECRET keys
# 3. In PRODUCTION: NODE_ENV=production, HTTPS only, rotate secrets monthly
