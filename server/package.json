{
  "name": "loyalty-app-server",
  "version": "1.0.0",
  "description": "Backend server for Loyalty App",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "dev:ml": "node scripts/start-ml.js",
    "dev:all": "concurrently -k -n api,ml -c blue,magenta \"npm:dev\" \"npm:dev:ml\"",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "node seed.js",
    "seed-and-start": "npm run migrate && node seed.js && npm start",
    "check": "node --check index.js",
    "migrate:007": "node scripts/apply-sql.js migrations/007_performance_indexes.sql",
    "migrate:008": "node scripts/apply-sql.js migrations/008_refresh_tokens.sql",
    "test": "jest tests/",
    "test:check": "npm run check && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-slow-down": "^3.1.0",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "resend": "^6.12.4",
    "sequelize": "^6.35.0",
    "stripe": "^22.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.4.0",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2"
  }
}
