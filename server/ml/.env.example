# ML-сервис подключается к той же Postgres, что и Express-бэкенд.
# Если переменная пустая или SYNTHETIC_FALLBACK=true — будет использован
# синтетический датасет (удобно для локальной разработки без БД).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loyalty_app

# Должен совпадать с ML_SERVICE_TOKEN в server/.env
ML_SERVICE_TOKEN=dev-token

# Куда сохраняются .pkl-артефакты обученных моделей
ARTIFACTS_DIR=./artifacts

# true → если БД недоступна, используется синтетика
# false → loader.py упадёт с RuntimeError (production-режим)
SYNTHETIC_FALLBACK=true

LOG_LEVEL=info
